# Jira Webhooks — Auto-trigger pipeline on story events
# Set a secret for HMAC-SHA256 signature validation (optional but recommended)
# WEBHOOK_SECRET=your-random-secret-here
# Comma-separated Jira statuses that trigger the pipeline
WEBHOOK_TRIGGER_STATUSES=In Progress,Selected for Development,To Do

# API Authentication — protects manual trigger and status endpoints
# Set a random secret; pass as: Authorization: Bearer <secret>
# API_SECRET=your-random-api-secret-here

# Performance testing
PERF_K6_BINARY=k6
# Legacy flat thresholds (used as fallback when per-type vars are absent)
PERF_THRESHOLDS_P95=2000
PERF_THRESHOLDS_P99=5000
PERF_THRESHOLDS_ERROR_RATE=0.01
PERF_VUS_MAX=50
PERF_SOAK_DURATION=30m
PERF_BASELINE_TOLERANCE=0.20
PERF_SKIP_SOAK=false
PERF_STORY_DESCRIPTION=

# ── Per-test-type SLA thresholds ──────────────────────────────────────────────
# Each test type runs under different conditions so tolerances differ.
# Latency in ms; error rate as fraction (0.01 = 1%).
PERF_LOAD_P95=2000      # load — normal traffic p95 target
PERF_LOAD_P99=4000      # load — normal traffic p99 target
PERF_LOAD_ERROR=0.01    # load — max acceptable error fraction
PERF_STRESS_P95=3500    # stress — elevated traffic p95 target
PERF_STRESS_P99=6000    # stress — elevated traffic p99 target
PERF_STRESS_ERROR=0.02  # stress — max acceptable error fraction
PERF_SPIKE_P95=5000     # spike — sudden burst p95 target
PERF_SPIKE_P99=9000     # spike — sudden burst p99 target
PERF_SPIKE_ERROR=0.05   # spike — max acceptable error fraction (5%)
PERF_SOAK_P95=2200      # soak — sustained long-run p95 target
PERF_SOAK_P99=4500      # soak — sustained long-run p99 target
PERF_SOAK_ERROR=0.005   # soak — max acceptable error fraction (0.5%)
PERF_SCALE_P95=3000     # scalability ramp p95 target
PERF_SCALE_P99=5500     # scalability ramp p99 target
PERF_SCALE_ERROR=0.015  # scalability ramp max error fraction
PERF_BREAK_P95=99999    # breakpoint — disabled (informational only)
PERF_BREAK_P99=99999    # breakpoint — disabled (informational only)
PERF_BREAK_ERROR=0.10   # breakpoint — max error fraction before abort

# ── Per-metric baseline regression tolerances ─────────────────────────────────
# Fraction above previous baseline that triggers a DEGRADED flag.
PERF_BASELINE_TOL_P95=0.15   # 15% increase in p95 = degraded
PERF_BASELINE_TOL_P99=0.20   # 20% increase in p99 = degraded
PERF_BASELINE_TOL_AVG=0.10   # 10% increase in avg = degraded
PERF_BASELINE_TOL_ERR=0.005  # absolute +0.5pp increase in errorRate = degraded
PERF_BASELINE_TOL_RPS=0.10   # 10% drop in req/s = degraded

# Rolling window: how many previous runs to store per key (default: 5)
PERF_BASELINE_WINDOW=5

# Near-threshold warning band (default: 0.10 = warn when within 10% of limit)
PERF_WARN_PCT=0.10

# ── Security testing (OWASP ZAP + custom checks) ─────────────────────────────
# ZAP daemon host/port (default: localhost:8080)
ZAP_HOST=localhost
ZAP_PORT=8080
# Full ZAP API URL (used by sec.execution.service)
ZAP_API_URL=http://localhost:8080
# Auto-start ZAP via Docker (true | false)
ZAP_DOCKER=false
# Set to true to auto-launch ZAP daemon if it is not already running
ZAP_AUTO_LAUNCH=false
# ZAP API key — set in ZAP GUI under Tools → Options → API
ZAP_API_KEY=8t95qio8f73b7k4of80ik3c0t3

# ============================================================================
# Proactive Healer — Fuzzy Text Matching (Added 2026-04-21)
# ============================================================================
# Minimum Levenshtein similarity (0.0–1.0) required before auto-healing a
# text-based locator.  Below this threshold the locator is flagged for manual
# review instead of being auto-patched.  Default: 0.70
HEALER_TEXT_SIMILARITY_THRESHOLD=0.70
# Set to "true" to make text comparison case-sensitive.  Default: false
HEALER_TEXT_CASE_SENSITIVE=false
# Scan type: baseline | full | api (default: baseline)
ZAP_SCAN_TYPE=baseline
# CVSS severity threshold that causes pipeline FAIL (critical|high|medium|low)
ZAP_FAIL_ON=high
# CVSS severity threshold that produces a WARN (medium|low)
ZAP_WARN_ON=medium
# Max total issues allowed before WARN triggers (0 = unlimited)
ZAP_MAX_ISSUES=0
# Active scan timeout in milliseconds (default: 1200000 = 20 min)
ZAP_SCAN_TIMEOUT_MS=1200000
# Spider timeout in milliseconds (default: 180000 = 3 min)
ZAP_SPIDER_TIMEOUT_MS=180000
# Spider crawl limits — max depth, duration (minutes), children per node
ZAP_SPIDER_MAX_DEPTH=5
ZAP_SPIDER_MAX_DURATION_MINS=3
ZAP_SPIDER_MAX_CHILDREN=10
# Passive scan wait in milliseconds (baseline mode — default: 15000 = 15 s)
ZAP_PASSIVE_WAIT_MS=15000
# ── k6 adversarial pentest probes (security pipeline Stage 4) ──────────────
# High error rate IS the expected outcome — 401/403/429 from auth rejection /
# rate-limiting are correct behavior. p95/p99 enforce server stays responsive.
SEC_PENTEST_P95=3000    # pentest p95 response time (ms)
SEC_PENTEST_P99=6000    # pentest p99 response time (ms)
SEC_PENTEST_ERROR=0.80  # pentest max error fraction (80% — rejections are expected)
# Active scan parallel threads per host (default: 5)
ZAP_ASCAN_THREADS=5
# Progress poll interval in milliseconds (default: 2000)
ZAP_POLL_INTERVAL_MS=2000
# Short description injected into the security agent for OWASP signal detection
SEC_STORY_DESCRIPTION=
# -- API security (G1) -----------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# -- Secrets provider (G2) -------------------------------------------------
# env | vault | aws
SECRETS_PROVIDER=env
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=
# VAULT_SECRET_PATH=secret/data/agentic-qa

# -- Pipeline concurrency (G3) ---------------------------------------------
PIPELINE_LOCK_TIMEOUT_MS=1800000

# -- Logging (G4) ----------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_SIZE_BYTES=20000000
LOG_MAX_FILES=5
LOG_MAX_AGE_DAYS=14

# -- Artifact retention (G4) -----------------------------------------------
ARTIFACT_RETENTION_DAYS=30

# -- Playwright execution (G5) ---------------------------------------------
PLAYWRIGHT_EXEC_TIMEOUT_MS=300000
PLAYWRIGHT_MAX_BUFFER_MB=50
PLAYWRIGHT_STREAM_OUTPUT=false

# --- Penetration Testing -------------------------------------------------------
# Enable the pentest pillar.  Set to true only when you have written
# authorisation to test the target.
PENTEST_ENABLED=true

PENTEST_TARGET_URL=http://localhost:3000
# COMMA-SEPARATED � only these hosts may be pentested
PENTEST_ALLOWED_HOSTS=localhost,127.0.0.1

PENTEST_FAIL_ON=critical
PENTEST_WARN_ON=high

# Optional: provide story context for the pentest planner when Jira is not available
PENTEST_STORY_SUMMARY=
PENTEST_STORY_DESCRIPTION=

# Nuclei
NUCLEI_BINARY=nuclei
NUCLEI_TEMPLATES_PATH=
NUCLEI_RATE_LIMIT=50
NUCLEI_TIMEOUT=10

# SQLMap
SQLMAP_BINARY=sqlmap
SQLMAP_API_PORT=8778
SQLMAP_LEVEL=2
SQLMAP_RISK=2
SQLMAP_TIMEOUT_MS=300000

# ffuf
FFUF_BINARY=ffuf
SECLIST_PATH=/usr/share/seclists
FFUF_RATE=100
FFUF_THREADS=40

# ZAP Authenticated Scan
PENTEST_AUTH_LOGIN_URL=
PENTEST_AUTH_USERNAME=Admin
PENTEST_AUTH_PASSWORD=admin123
PENTEST_AUTH_USER_FIELD=username
PENTEST_AUTH_PASS_FIELD=password
PENTEST_AUTH_LOGGED_IN=\Qsign-out\E
ZAP_IGNORE_SSL_ERRORS=true

# Jira Integration (optional custom fields)
JIRA_CVSS_FIELD_ID=
JIRA_SECURITY_LEVEL_ID=
